# Redis (required — start with: docker compose up -d redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Backend port
PORT=3000

# GitHub token (strongly recommended — avoids the 60 req/hour unauthenticated limit)
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Python executable (change to python3 if `python` is not in PATH)
PYTHON_CMD=python
